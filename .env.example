# Binance API (for scout and executor)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Telegram bot (for messenger)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# SQLite DB for orders and balance (optional; default: ./data/algotrader.db)
# In Docker, executor and monitor use /data/algotrader.db with a shared volume.
# DATABASE_PATH=/data/algotrader.db
